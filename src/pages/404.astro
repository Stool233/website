---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-6xl font-bold text-ink dark:text-ink-dark mb-4">404</h1>
    <p class="text-lg text-ink-secondary dark:text-ink-dark-secondary mb-8">
      The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="px-5 py-2.5 rounded-xl bg-accent text-white text-sm font-medium hover:bg-accent/90 transition-colors"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
